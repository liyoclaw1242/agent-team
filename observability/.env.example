# Observability Stack — Environment Variables
# Copy to .env and fill in values before running docker compose

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
GF_SERVER_ROOT_URL=http://localhost:3002

# Faro (frontend → Alloy)
FARO_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# OTel Collector
OTEL_COLLECTOR_HOST=0.0.0.0

# Loki
LOKI_RETENTION_PERIOD=168h

# Tempo
TEMPO_RETENTION_PERIOD=168h

# Prometheus
PROMETHEUS_RETENTION=15d

# Port mappings (change if defaults conflict with local services)
OTEL_GRPC_PORT=14317
OTEL_HTTP_PORT=14318
FARO_PORT=12347
ALLOY_UI_PORT=12345
TEMPO_PORT=3200
LOKI_PORT=3101
PROMETHEUS_PORT=9099
GRAFANA_PORT=3002
